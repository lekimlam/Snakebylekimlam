{
  "entities": {
    "UserPrivate": {
      "title": "UserPrivate",
      "description": "Private user data (email, role)",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["admin", "player"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "role", "createdAt"]
    },
    "UserPublic": {
      "title": "UserPublic",
      "description": "Public user data (displayName, score) for leaderboard",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "highestScore": { "type": "number" }
      },
      "required": ["uid", "displayName", "highestScore"]
    }
  },
  "firestore": {
    "users_private/{userId}": {
      "schema": { "$ref": "#/entities/UserPrivate" },
      "description": "Private user data"
    },
    "users_public/{userId}": {
      "schema": { "$ref": "#/entities/UserPublic" },
      "description": "Public user data for leaderboard"
    }
  }
}
